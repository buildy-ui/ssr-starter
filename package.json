{
  "name": "@buildy-ui/ssr-starter",
  "version": "0.0.1",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "author": {
    "name": "buildy-ui",
    "url": "https://buildy.tw"
  },
  "repository": "https://github.com/buildy-ui/ssr-starter.git",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx turbo run dev",
    "build": "bunx turbo run build",
    "test": "bunx turbo run test",
    "lint": "bunx turbo run lint",
    "dev:ssr": "bunx turbo run dev --filter=./apps/ssr",
    "dev:server:ssr": "bunx turbo run dev:server --filter=./apps/ssr",
    "dev:cms": "bunx turbo run dev --filter=./apps/cms",
    "dev:api": "bunx turbo run dev --filter=./apps/api",
    "build:cms": "bunx turbo run build --filter=./apps/cms",
    "preview:cms": "bunx turbo run preview --filter=./apps/cms"
  },
  "packageManager": "bun@1.3.3",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "turbo": "^2.5.6"
  }
}
