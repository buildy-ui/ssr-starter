# GraphQL API endpoint
# - Set to WordPress GraphQL directly, or to the local proxy:
#   GRAPHQL_ENDPOINT=http://localhost:5001/graphql
GRAPHQL_ENDPOINT=https://example.com/graphql

# S3 Assets URL for fonts and other static assets
S3_ASSETS_URL=https://s3.cloud.example/38aece89

MAINDB=LMDB
BACKUPDB=JsonDB
GRAPHQL_MODE=GETMODE
NODE_ENV=development