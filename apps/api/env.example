# Port for local GraphQL proxy
PORT=5001

# Real upstream WordPress GraphQL endpoint (required to "warm" the cache)
UPSTREAM_GRAPHQL_ENDPOINT=https://example.com/graphql

# Disk cache directory (relative to apps/api)
CACHE_DIR=./data/graphql-cache

# Allow CMS SPA to call this API from a different origin during development
CORS_ORIGIN=*


